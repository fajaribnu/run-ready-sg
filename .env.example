# ============================================
# RunReady SG — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ============================================

# --- Database (AWS RDS PostgreSQL + PostGIS) ---
# For shared team RDS instance:
DB_HOST=runready-db.cjw44gsugtna.ap-southeast-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=runready
DB_USER=runready_user
DB_PASSWORD=RunReady2026Sg
DATABASE_URL=postgresql://runready_user:RunReady2026Sg@runready-db.cjw44gsugtna.ap-southeast-1.rds.amazonaws.com:5432/runready
# For local Docker development (uncomment):
# DB_HOST=localhost
# DB_PASSWORD=changeme
# DATABASE_URL=postgresql://runready_user:changeme@localhost:5432/runready

# --- data.gov.sg API ---
DATA_GOV_API_KEY=your_api_key_here

# --- AWS Services ---
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# --- AWS SES (Email Alerts) ---
SES_SENDER_EMAIL=alerts@runready.sg

# --- OneMap API ---
ONEMAP_EMAIL=your_email
ONEMAP_PASSWORD=your_password

# --- App Config ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
